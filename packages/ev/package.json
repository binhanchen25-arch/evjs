{
  "name": "@evjs/ev",
  "version": "0.0.0",
  "description": "Framework API, configuration, and build orchestration for evjs",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "default": "./esm/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  },
  "license": "MIT",
  "author": "xusd320",
  "dependencies": {
    "@evjs/manifest": "*",
    "@evjs/shared": "*",
    "@logtape/logtape": "^2.0.4",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@utoo/pack": "^1.4.2",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "evjs",
    "config",
    "plugin",
    "typescript"
  ]
}
