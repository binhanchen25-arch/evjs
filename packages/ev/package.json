    },
    "./_internal/server/server-functions": {
      "types": "./esm/_internal/generated/server/server-functions.d.ts",
      "import": "./esm/_internal/generated/server/server-functions.js",
      "default": "./esm/_internal/generated/server/server-functions.js"
    }
  },
  "scripts": {
    "build": "rm -rf esm && tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "homepage": "https://github.com/afx-team/evjs#readme",
  "bugs": {
    "url": "https://github.com/afx-team/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afx-team/evjs.git"
  },
  "license": "MIT",
  "author": "xusd320",
  "dependencies": {
    "@evjs/client": "*",
    "@evjs/server": "*",
    "@evjs/shared": "*",
    "@tanstack/react-router": "^1.168.3",
    "@logtape/logtape": "^2.0.4",
    "@swc/core": "^1.15.21",
    "@utoo/pack": "^1.4.17",
    "domparser-rs": "^0.1.0",
    "execa": "^9.6.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-server-dom-webpack": "^19.2.5"
  },
