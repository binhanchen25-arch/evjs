      "default": "./esm/server-context/index.js"
    },
    "./transport": {
      "types": "./esm/transport/index.d.ts",
      "import": "./esm/transport/index.js",
      "default": "./esm/transport/index.js"
    },
    "./deployment": {
      "types": "./esm/deployment/index.d.ts",
