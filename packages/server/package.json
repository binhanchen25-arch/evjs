{
  "name": "@evjs/server",
  "version": "0.0.0",
  "description": "Server-side runtime for the evjs framework",
  "dependencies": {
    "@evjs/shared": "*",
    "@hono/node-server": "^1.19.11",
    "@logtape/logtape": "^2.0.4",
    "hono": "^4.12.9"
  },
  "homepage": "https://github.com/evaijs/evjs#readme",
  "bugs": {
    "url": "https://github.com/evaijs/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evaijs/evjs.git"
  },
  "license": "MIT",
  "author": "xusd320",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "default": "./esm/index.js"
    },
    "./register": {
      "types": "./esm/functions/register.d.ts",
      "import": "./esm/functions/register.js",
      "default": "./esm/functions/register.js"
    },
    "./node": {
      "types": "./esm/environments/node.d.ts",
      "import": "./esm/environments/node.js",
      "default": "./esm/environments/node.js"
    },
    "./app": {
      "types": "./esm/app.d.ts",
      "import": "./esm/app.js",
      "default": "./esm/app.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "evjs",
    "server",
    "hono",
    "rpc",
    "server-functions",
    "typescript"
  ]
}
