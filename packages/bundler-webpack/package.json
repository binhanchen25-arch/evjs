{
  "name": "@evjs/bundler-webpack",
  "version": "0.0.0",
  "description": "Webpack bundler adapter for validating evjs framework build contracts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "default": "./esm/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf esm && tsc && cp src/adapter/server-function-loader.cjs src/adapter/rsc-client-reference-loader.cjs esm/adapter/",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "keywords": [
    "evjs",
    "webpack",
    "bundler"
  ],
  "author": "xusd320",
  "license": "MIT",
  "dependencies": {
    "@evjs/ev": "*",
    "@logtape/logtape": "^2.0.4",
    "css-loader": "^7.1.4",
    "memfs": "^4.57.8",
    "mini-css-extract-plugin": "^2.10.2",
    "react-server-dom-webpack": "^19.2.5",
    "swc-loader": "^0.2.7",
    "webpack": "^5.106.2",
    "webpack-dev-server": "^5.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "homepage": "https://github.com/afx-team/evjs#readme",
  "bugs": {
    "url": "https://github.com/afx-team/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afx-team/evjs.git"
  }
}
