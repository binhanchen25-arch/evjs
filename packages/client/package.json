{
  "name": "@evjs/client",
  "version": "0.0.0",
  "description": "Client-side runtime for the evjs framework",
  "dependencies": {
    "@evjs/shared": "*",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-server-dom-webpack": "^19.2.5"
  },
  "peerDependenciesMeta": {
    "react-server-dom-webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0",
    "react-server-dom-webpack": "^19.2.5",
    "typescript": "^6.0.2"
  },
  "homepage": "https://github.com/afx-team/evjs#readme",
  "bugs": {
    "url": "https://github.com/afx-team/evjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afx-team/evjs.git"
  },
  "license": "MIT",
  "author": "xusd320",
  "type": "module",
  "types": "./esm/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "default": "./esm/index.js"
    },
    "./transport": {
      "types": "./esm/transport.d.ts",
      "import": "./esm/transport.js",
      "default": "./esm/transport.js"
    },
    "./internal": {
      "types": "./esm/internal.d.ts",
      "import": "./esm/internal.js",
      "default": "./esm/internal.js"
    },
    "./internal/server-functions": {
      "types": "./esm/server-function-runtime.d.ts",
      "import": "./esm/server-function-runtime.js",
      "default": "./esm/server-function-runtime.js"
    },
    "./internal/page-context": {
      "types": "./esm/page-context.d.ts",
      "import": "./esm/page-context.js",
      "default": "./esm/page-context.js"
    },
    "./internal/react-page": {
      "types": "./esm/react-page.d.ts",
      "import": "./esm/react-page.js",
      "default": "./esm/react-page.js"
    },
    "./internal/rsc-page-context": {
      "types": "./esm/rsc-page-context.d.ts",
      "import": "./esm/rsc-page-context.js",
      "default": "./esm/rsc-page-context.js"
    },
    "./internal/rsc-runtime": {
      "types": "./esm/rsc-runtime.d.ts",
      "import": "./esm/rsc-runtime.js",
      "default": "./esm/rsc-runtime.js"
    },
    "./internal/route-types": {
      "types": "./esm/route-types.d.ts",
      "import": "./esm/route-types.js",
      "default": "./esm/route-types.js"
    }
  },
  "scripts": {
    "build": "rm -rf esm && tsc",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "esm"
  ],
  "keywords": [
    "evjs",
    "react",
    "client",
    "tanstack",
    "routing",
    "server-functions",
    "typescript"
  ]
}
