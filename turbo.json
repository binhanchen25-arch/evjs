{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "esm/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "@evjs/ev#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/{AGENT.md,AGENTS.md,ARCHITECTURE.md,CONTRIBUTING.md,README.md,package-lock.json}",
        "$TURBO_ROOT$/docs/{docs,i18n}/**/*.md",
        "$TURBO_ROOT$/examples/**",
        "!$TURBO_ROOT$/examples/**/{dist,.turbo,.turbopack,node_modules}/**",
        "!$TURBO_ROOT$/examples/**/route-types.d.ts",
        "$TURBO_ROOT$/packages/*/{README.md,package.json}",
        "$TURBO_ROOT$/packages/create-app/templates/*",
        "$TURBO_ROOT$/scripts/**"
      ]
    },
    "@evjs/create-app#test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/examples/**",
        "!$TURBO_ROOT$/examples/**/{dist,.turbo,.turbopack,node_modules}/**",
        "!$TURBO_ROOT$/examples/**/route-types.d.ts",
        "$TURBO_ROOT$/packages/create-app/templates/*"
      ]
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tsconfig.test.json"]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"]
    },
    "release": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
